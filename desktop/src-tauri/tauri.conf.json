{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Breakpoint",
  "version": "0.1.0",
  "identifier": "com.breakpoint.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Breakpoint",
        "url": "index.html",
        "width": 1180,
        "height": 780,
        "minWidth": 920,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
