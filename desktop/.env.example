# Optional: Next.js origin if not http://localhost:3000 (no trailing slash).
# ANTHROPIC_API_KEY lives in breakpoint/.env.local — run `npm run dev` in /breakpoint.
# VITE_BREAKPOINT_API_ORIGIN=https://your-deployed-app.example

